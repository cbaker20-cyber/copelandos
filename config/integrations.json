{
  "version": 1,
  "policy": "honest-status-only",
  "description": "CopelandOS integration registry for the mobile command-center roadmap. External systems are never marked connected without a live check.",
  "flow": [
    "phone/Siri/Shortcut/share-sheet",
    "copelandos-inbox",
    "idea-classifier",
    "planner",
    "provider-router",
    "safe-tool-registry",
    "obsidian-memory",
    "cursor-codex-task",
    "draft-pr",
    "morning-report"
  ],
  "integrations": [
    {
      "id": "iphone-shortcuts",
      "displayName": "iPhone Shortcuts and Siri",
      "layer": "capture",
      "implementationStatus": "documented",
      "connectionKind": "mobile-client",
      "entrypoints": ["POST /api/capture/idea"],
      "requiredEnvVars": [],
      "allowedActions": ["submit_text_idea", "submit_share_sheet_text", "open_dashboard"],
      "blockedActions": ["execute_task", "send_email", "merge_pr"],
      "riskLevel": "safe",
      "docs": ["docs/mobile-capture.md", "docs/mobile-command-center.md"],
      "notes": "Shortcut setup is documented. The Worker accepts capture payloads; the iPhone Shortcut itself is not bundled in this repo."
    },
    {
      "id": "copelandos-inbox",
      "displayName": "CopelandOS Inbox",
      "layer": "capture",
      "implementationStatus": "implemented",
      "connectionKind": "internal-module",
      "entrypoints": ["POST /api/capture/idea", "GET /api/ideas"],
      "requiredEnvVars": [],
      "allowedActions": ["capture_idea", "list_ideas", "triage_idea"],
      "blockedActions": ["execute_idea_without_review", "store_private_student_data"],
      "riskLevel": "safe",
      "docs": ["docs/mobile-capture.md", "docs/mobile-command-center.md"],
      "notes": "In-memory idea store suitable for foundation testing; persistence is future work."
    },
    {
      "id": "idea-classifier",
      "displayName": "Idea Classifier",
      "layer": "brain",
      "implementationStatus": "implemented",
      "connectionKind": "internal-module",
      "entrypoints": ["src/ideaClassifier.js"],
      "requiredEnvVars": [],
      "allowedActions": ["classify_text", "estimate_risk", "suggest_skill"],
      "blockedActions": ["auto_execute_high_risk_action"],
      "riskLevel": "safe",
      "docs": ["docs/ai-brain.md", "docs/overnight-control-loop.md"],
      "notes": "Deterministic classifier with advisory output only."
    },
    {
      "id": "planner",
      "displayName": "Planner and AI Council",
      "layer": "brain",
      "implementationStatus": "implemented",
      "connectionKind": "internal-module",
      "entrypoints": ["POST /api/plan", "POST /api/council"],
      "requiredEnvVars": [],
      "allowedActions": ["create_plan", "select_roles", "create_mock_council_result"],
      "blockedActions": ["claim_live_council_without_provider", "skip_human_confirmation"],
      "riskLevel": "safe",
      "docs": ["docs/ai-brain.md", "docs/ai-council.md", "docs/overnight-control-loop.md"],
      "notes": "Council route produces mock role output until a configured provider route is explicitly used."
    },
    {
      "id": "provider-router",
      "displayName": "Provider Router",
      "layer": "routing",
      "implementationStatus": "implemented",
      "connectionKind": "external-provider",
      "entrypoints": ["GET /api/providers", "POST /api/providers/route", "POST /api/ai/route"],
      "requiredEnvVars": [],
      "optionalEnvVars": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "GROQ_API_KEY", "CEREBRAS_API_KEY", "GEMINI_API_KEY", "OPENROUTER_API_KEY", "OLLAMA_BASE_URL", "LITELLM_BASE_URL"],
      "allowedActions": ["select_configured_provider", "explain_fallback_chain", "show_local_fallback"],
      "blockedActions": ["fake_provider_connection", "escalate_paid_provider_without_policy"],
      "riskLevel": "medium",
      "docs": ["docs/provider-strategy.md", "docs/provider-routing-roadmap.md"],
      "notes": "Routing is implemented; providers are configured only when matching environment variables exist. Live provider health is not assumed."
    },
    {
      "id": "tool-mcp-registry",
      "displayName": "Tool and MCP Allowlist Registry",
      "layer": "safety",
      "implementationStatus": "implemented",
      "connectionKind": "policy-registry",
      "entrypoints": ["GET /api/tools", "POST /api/tools/check", "GET /api/mcp/registry", "POST /api/mcp/check"],
      "requiredEnvVars": [],
      "allowedActions": ["check_tool_permission", "check_mcp_permission", "list_allowlisted_tools"],
      "blockedActions": ["install_random_mcp", "arbitrary_shell", "delete_files", "send_email"],
      "riskLevel": "safe",
      "docs": ["docs/tool-permissions.md", "docs/mcp-policy.md", "docs/overnight-control-loop.md"],
      "notes": "Allowlist-first policy is config-backed. Unknown tools and servers are blocked."
    },
    {
      "id": "obsidian-git-vault",
      "displayName": "Obsidian Git Vault",
      "layer": "memory",
      "implementationStatus": "implemented",
      "connectionKind": "external-storage",
      "entrypoints": ["POST /api/vault/write", "POST /api/obsidian/open"],
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"],
      "optionalEnvVars": ["VAULT_ROOT", "VAULT_BRANCH", "OBSIDIAN_VAULT"],
      "allowedActions": ["write_sanitized_note", "return_obsidian_uri", "mock_preview_without_credentials"],
      "blockedActions": ["commit_secrets", "write_private_student_data", "delete_vault"],
      "riskLevel": "medium",
      "docs": ["docs/obsidian-vault.md", "docs/obsidian-cursor-workflow.md"],
      "notes": "Writes are mocked unless GitHub vault credentials are configured. Obsidian URI route returns a URI; it does not open apps server-side."
    },
    {
      "id": "cursor-codex-task-queue",
      "displayName": "Cursor and Codex Task Queue",
      "layer": "automation",
      "implementationStatus": "scaffold-only",
      "connectionKind": "task-brief",
      "entrypoints": ["POST /api/ideas/:id/cursor-prompt", "POST /api/ideas/:id/codex-prompt", "POST /api/agents/cursor-prompt", "POST /api/agents/codex-prompt"],
      "requiredEnvVars": [],
      "allowedActions": ["generate_task_prompt", "mark_idea_ready_for_cursor", "mark_idea_ready_for_codex"],
      "blockedActions": ["execute_task", "auto_push", "auto_merge", "auto_deploy"],
      "riskLevel": "medium",
      "docs": ["docs/cursor-codex-workflow.md", "docs/obsidian-cursor-workflow.md"],
      "notes": "Prompts are generated for a human or external agent to review. No task runner is connected by this registry."
    },
    {
      "id": "draft-pr-review-loop",
      "displayName": "Draft PR Review Loop",
      "layer": "review",
      "implementationStatus": "documented",
      "connectionKind": "process",
      "entrypoints": ["docs/overnight-control-loop.md"],
      "requiredEnvVars": [],
      "allowedActions": ["open_draft_pr_after_tests", "record_checks_run", "summarize_review_status"],
      "blockedActions": ["merge_pr", "mark_ready_without_review", "delete_branch"],
      "riskLevel": "medium",
      "docs": ["docs/overnight-control-loop.md", "docs/mobile-command-center.md"],
      "notes": "Workflow guidance only. GitHub status polling is intentionally not connected in the foundation route."
    },
    {
      "id": "morning-report",
      "displayName": "Morning Report",
      "layer": "reporting",
      "implementationStatus": "documented",
      "connectionKind": "workflow",
      "entrypoints": ["docs/overnight-control-loop.md"],
      "requiredEnvVars": [],
      "allowedActions": ["summarize_project_status", "list_blockers", "draft_next_steps"],
      "blockedActions": ["claim_unverified_results", "send_report_email"],
      "riskLevel": "safe",
      "docs": ["docs/overnight-control-loop.md", "docs/mobile-command-center.md"],
      "notes": "Report format is documented. Email delivery remains draft-only and out of scope for automation."
    }
  ]
}
