{
  "version": 1,
  "statusPolicy": "Honest scaffold status only. External systems are never marked connected by config alone.",
  "architecture": [
    "phone-siri-shortcut-share-sheet",
    "copelandos-inbox",
    "classifier",
    "planner",
    "provider-router",
    "ai-council",
    "safe-tool-registry",
    "obsidian-memory",
    "cursor-codex-task",
    "draft-pr",
    "review-status"
  ],
  "integrations": [
    {
      "id": "iphone-shortcuts",
      "displayName": "iPhone Shortcuts",
      "category": "mobile-capture",
      "stage": "scaffolded",
      "mode": "inbound",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": ["ALLOWED_ORIGIN"],
      "allowedActions": ["post_idea_capture", "open_dashboard", "sync_vault"],
      "blockedActions": ["execute_task", "send_email", "merge_pr"],
      "endpoint": "/api/capture/idea",
      "notes": "Shortcut/share-sheet capture should only enqueue ideas for review."
    },
    {
      "id": "mobile-widget",
      "displayName": "Mobile Widget",
      "category": "mobile-capture",
      "stage": "planned",
      "mode": "inbound",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": ["ALLOWED_ORIGIN"],
      "allowedActions": ["open_capture", "show_morning_status"],
      "blockedActions": ["execute_task", "send_email", "delete_files"],
      "notes": "Future native wrapper or PWA widget for one-tap capture and morning report viewing."
    },
    {
      "id": "copelandos-inbox",
      "displayName": "CopelandOS Inbox",
      "category": "core-loop",
      "stage": "implemented",
      "mode": "internal",
      "riskLevel": "safe",
      "status": "implemented",
      "requiredEnvVars": [],
      "allowedActions": ["capture_idea", "list_ideas", "triage_idea"],
      "blockedActions": ["auto_execute_idea"],
      "endpoint": "/api/ideas",
      "notes": "Current reliable entry point for idea capture and triage."
    },
    {
      "id": "classifier",
      "displayName": "Idea Classifier",
      "category": "core-loop",
      "stage": "implemented",
      "mode": "internal",
      "riskLevel": "safe",
      "status": "implemented",
      "requiredEnvVars": [],
      "allowedActions": ["classify_idea", "estimate_risk"],
      "blockedActions": ["approve_high_risk_action"],
      "notes": "Deterministic classifier tags ideas for review before planning."
    },
    {
      "id": "planner",
      "displayName": "AI Brain Planner",
      "category": "core-loop",
      "stage": "implemented",
      "mode": "internal",
      "riskLevel": "safe",
      "status": "implemented",
      "requiredEnvVars": [],
      "allowedActions": ["create_plan", "create_task_brief", "select_roles"],
      "blockedActions": ["execute_plan_without_review"],
      "endpoint": "/api/plan",
      "notes": "Produces plans and task briefs; execution remains separate."
    },
    {
      "id": "provider-router",
      "displayName": "Provider Router",
      "category": "ai-routing",
      "stage": "implemented",
      "mode": "internal",
      "riskLevel": "safe",
      "status": "implemented",
      "requiredEnvVars": [],
      "allowedActions": ["select_configured_provider", "explain_route", "list_fallbacks"],
      "blockedActions": ["fake_provider_connection", "spend_without_budget_guard"],
      "endpoint": "/api/providers/route",
      "notes": "Routes by configured environment variables and reports no-provider states honestly."
    },
    {
      "id": "ai-council",
      "displayName": "AI Council",
      "category": "ai-routing",
      "stage": "scaffolded",
      "mode": "mock",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": [],
      "allowedActions": ["produce_mock_review", "prepare_multi_role_prompt"],
      "blockedActions": ["claim_live_multi_model_consensus"],
      "endpoint": "/api/council",
      "notes": "Mock-mode council prompt generation exists; live multi-model calls are future work."
    },
    {
      "id": "safe-tool-registry",
      "displayName": "Tool and MCP Allowlist",
      "category": "tool-safety",
      "stage": "implemented",
      "mode": "internal",
      "riskLevel": "safe",
      "status": "implemented",
      "requiredEnvVars": [],
      "allowedActions": ["check_tool_permission", "check_mcp_permission", "list_allowlist"],
      "blockedActions": ["install_unreviewed_mcp", "arbitrary_shell", "delete_files"],
      "endpoint": "/api/registry/summary",
      "notes": "Allowlist-first registry blocks risky tool families and scaffold-only MCP servers."
    },
    {
      "id": "obsidian-memory",
      "displayName": "Obsidian Git Vault",
      "category": "memory",
      "stage": "scaffolded",
      "mode": "safe-write",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"],
      "allowedActions": ["write_note", "preview_note", "build_obsidian_uri"],
      "blockedActions": ["delete_vault", "make_public", "store_private_student_data"],
      "endpoint": "/api/vault/write",
      "notes": "Writes use mock preview unless a private vault repo is configured."
    },
    {
      "id": "cursor-codex-task",
      "displayName": "Cursor/Codex Task Queue",
      "category": "automation",
      "stage": "scaffolded",
      "mode": "draft-only",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": [],
      "allowedActions": ["generate_cursor_prompt", "generate_codex_prompt"],
      "blockedActions": ["auto_execute_prompt", "auto_merge", "auto_deploy"],
      "endpoint": "/api/agents/cursor-prompt",
      "notes": "Generates scoped prompts for humans or supervised agents; does not run them."
    },
    {
      "id": "draft-pr",
      "displayName": "Draft PR Workflow",
      "category": "automation",
      "stage": "planned",
      "mode": "draft-only",
      "riskLevel": "medium",
      "status": "scaffold-only",
      "requiredEnvVars": ["GITHUB_TOKEN"],
      "allowedActions": ["prepare_branch", "prepare_pr_body", "read_checks"],
      "blockedActions": ["merge_pr", "mark_ready", "delete_branch", "deploy"],
      "notes": "Future connector should create draft PRs only after tests pass and safety checks are recorded."
    },
    {
      "id": "morning-report",
      "displayName": "Morning Report",
      "category": "status",
      "stage": "planned",
      "mode": "read-only",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": [],
      "allowedActions": ["summarize_inbox", "summarize_projects", "summarize_pr_checks"],
      "blockedActions": ["send_email", "post_without_review"],
      "notes": "Future report should summarize overnight progress and blockers inside CopelandOS."
    },
    {
      "id": "review-status",
      "displayName": "Review Status Return",
      "category": "status",
      "stage": "planned",
      "mode": "read-only",
      "riskLevel": "safe",
      "status": "scaffold-only",
      "requiredEnvVars": ["GITHUB_TOKEN"],
      "allowedActions": ["read_pr_status", "read_check_status", "append_dashboard_status"],
      "blockedActions": ["approve_own_pr", "merge_pr", "dismiss_reviews"],
      "notes": "Future read-only status should flow back to dashboard and Obsidian notes."
    }
  ],
  "controlLoop": [
    { "step": 1, "name": "Capture", "integrationId": "iphone-shortcuts", "from": "phone/Siri/Shortcut/share sheet", "to": "CopelandOS inbox" },
    { "step": 2, "name": "Classify", "integrationId": "classifier", "from": "inbox", "to": "risk and project labels" },
    { "step": 3, "name": "Plan", "integrationId": "planner", "from": "classified idea", "to": "reviewable plan" },
    { "step": 4, "name": "Route", "integrationId": "provider-router", "from": "task profile", "to": "configured provider or local fallback" },
    { "step": 5, "name": "Council", "integrationId": "ai-council", "from": "complex task", "to": "multi-role critique" },
    { "step": 6, "name": "Authorize Tools", "integrationId": "safe-tool-registry", "from": "planned action", "to": "allow/deny/confirmation decision" },
    { "step": 7, "name": "Remember", "integrationId": "obsidian-memory", "from": "approved note", "to": "private vault preview or write" },
    { "step": 8, "name": "Queue Work", "integrationId": "cursor-codex-task", "from": "task brief", "to": "Cursor/Codex prompt" },
    { "step": 9, "name": "Draft PR", "integrationId": "draft-pr", "from": "tested branch", "to": "draft PR" },
    { "step": 10, "name": "Report Back", "integrationId": "morning-report", "from": "PR/check status", "to": "CopelandOS morning report" }
  ],
  "morningReport": {
    "sections": [
      "overnight_summary",
      "draft_prs_opened",
      "tests_checks",
      "blocked_repositories",
      "safety_notes",
      "next_review_actions"
    ],
    "delivery": "dashboard-first; Obsidian note optional; email only as unsent draft"
  }
}
