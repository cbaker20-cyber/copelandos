{
  "version": 1,
  "policy": "review-first-safe-integrations",
  "description": "CopelandOS integration registry. Integrations are scaffolded or configured here before any connector is exposed in the dashboard.",
  "architecture": [
    "phone/Siri/Shortcut/share sheet",
    "CopelandOS inbox",
    "classifier",
    "planner",
    "provider router or AI council",
    "safe tool registry",
    "Obsidian memory",
    "Cursor/Codex task",
    "draft PR",
    "review status back into CopelandOS"
  ],
  "integrations": [
    {
      "id": "iphone-shortcuts",
      "displayName": "iPhone Shortcuts",
      "category": "mobile-capture",
      "status": "scaffold-only",
      "mode": "inbox-post",
      "description": "Siri, widget, share sheet, and x-callback-url capture into the CopelandOS idea inbox.",
      "riskLevel": "safe",
      "allowedOperations": ["post_idea", "open_dashboard", "show_capture_status"],
      "blockedOperations": ["execute_task", "send_email", "run_local_action"],
      "confirmationRequired": false,
      "requiredEnvVars": ["ALLOWED_ORIGIN"],
      "notes": "Future Shortcut should POST only to /api/capture/idea and display the returned triage status."
    },
    {
      "id": "copelandos-inbox",
      "displayName": "CopelandOS Inbox",
      "category": "brain",
      "status": "allowed",
      "mode": "internal",
      "description": "Review-first idea capture store backed by deterministic validation and triage states.",
      "riskLevel": "safe",
      "allowedOperations": ["capture_idea", "list_ideas", "triage_idea"],
      "blockedOperations": ["execute_idea", "auto_assign_private_student_data"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "notes": "Ideas are not executed automatically."
    },
    {
      "id": "idea-classifier",
      "displayName": "Idea Classifier",
      "category": "brain",
      "status": "allowed",
      "mode": "deterministic-first",
      "description": "Classifies captured ideas by project, skill, and risk before planning.",
      "riskLevel": "safe",
      "allowedOperations": ["classify_idea", "suggest_next_action"],
      "blockedOperations": ["auto_execute", "override_human_review"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "notes": "AI augmentation can be added later, but deterministic rules remain the fallback."
    },
    {
      "id": "planner",
      "displayName": "Planner",
      "category": "brain",
      "status": "allowed",
      "mode": "internal",
      "description": "Converts reviewed ideas into safe implementation briefs and role-aware plans.",
      "riskLevel": "safe",
      "allowedOperations": ["create_plan", "create_task_brief", "select_council_roles"],
      "blockedOperations": ["auto_merge", "auto_deploy", "auto_send"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "notes": "Plans are advisory until a human or agent opens a scoped task branch."
    },
    {
      "id": "provider-router",
      "displayName": "Provider Router",
      "category": "ai-routing",
      "status": "allowed",
      "mode": "configured-env-only",
      "description": "Routes tasks across configured AI providers with local fallback guidance.",
      "riskLevel": "medium",
      "allowedOperations": ["route_task", "explain_route", "list_provider_status"],
      "blockedOperations": ["spend_without_budget_guard", "claim_unconfigured_provider_connected"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "notes": "Provider status is configured from environment variables only; live health checks are future work."
    },
    {
      "id": "ai-council",
      "displayName": "AI Council",
      "category": "ai-routing",
      "status": "scaffold-only",
      "mode": "mock-until-provider-configured",
      "description": "Multi-role planning review for complex tasks when providers and budgets are configured.",
      "riskLevel": "medium",
      "allowedOperations": ["draft_council_prompt", "run_mock_council"],
      "blockedOperations": ["run_paid_council_without_budget", "execute_council_decision"],
      "confirmationRequired": true,
      "requiredEnvVars": ["OPENROUTER_API_KEY"],
      "notes": "Mock council output is available now; live multi-model council is proposed only."
    },
    {
      "id": "tool-mcp-registry",
      "displayName": "Tool + MCP Registry",
      "category": "tool-safety",
      "status": "allowed",
      "mode": "allowlist-first",
      "description": "Single allowlist for safe tools and MCP servers before any agent action.",
      "riskLevel": "medium",
      "allowedOperations": ["list_tools", "check_tool", "list_mcp_servers", "check_mcp_server"],
      "blockedOperations": ["install_unlisted_mcp", "arbitrary_shell", "delete_files"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "notes": "New MCP servers must land in config/mcp-servers.json before use."
    },
    {
      "id": "obsidian-vault",
      "displayName": "Obsidian Git Vault",
      "category": "memory",
      "status": "allowed-with-confirmation",
      "mode": "github-or-mock",
      "description": "Private memory workflow for project notes, decisions, research, daily notes, and ideas.",
      "riskLevel": "medium",
      "allowedOperations": ["write_note", "open_obsidian_uri", "create_daily_note", "create_project_update"],
      "blockedOperations": ["delete_vault", "make_public", "store_private_student_data"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"],
      "notes": "Writes validate paths and content; private student data is blocked."
    },
    {
      "id": "cursor-codex-task-queue",
      "displayName": "Cursor/Codex Task Queue",
      "category": "implementation",
      "status": "scaffold-only",
      "mode": "prompt-generation",
      "description": "Turns reviewed plans into scoped Cursor or Codex prompts that open draft PRs.",
      "riskLevel": "safe",
      "allowedOperations": ["generate_cursor_prompt", "generate_codex_prompt", "record_task_status"],
      "blockedOperations": ["auto_push_to_main", "auto_merge", "auto_deploy"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN"],
      "notes": "Current implementation generates prompts; queue persistence is future work."
    },
    {
      "id": "github-pr-supervisor",
      "displayName": "GitHub PR Supervisor",
      "category": "review-status",
      "status": "scaffold-only",
      "mode": "read-only",
      "description": "Reads PR, review, and check status back into CopelandOS morning reports.",
      "riskLevel": "safe",
      "allowedOperations": ["list_prs", "read_checks", "summarize_review_status"],
      "blockedOperations": ["merge_pr", "close_pr", "delete_branch"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN"],
      "notes": "No live GitHub status is queried by the foundation route yet."
    },
    {
      "id": "gmail-draft",
      "displayName": "Gmail Drafts",
      "category": "communications",
      "status": "allowed-with-confirmation",
      "mode": "draft-only",
      "description": "Creates Gmail drafts for human review. Sending is permanently blocked.",
      "riskLevel": "medium",
      "allowedOperations": ["create_draft"],
      "blockedOperations": ["send_message", "delete_message", "modify_labels"],
      "confirmationRequired": true,
      "requiredEnvVars": ["GMAIL_CLIENT_ID", "GMAIL_CLIENT_SECRET", "GMAIL_REFRESH_TOKEN"],
      "notes": "Gmail operations remain draft-only."
    },
    {
      "id": "morning-report",
      "displayName": "Morning Report",
      "category": "review-status",
      "status": "scaffold-only",
      "mode": "summary-only",
      "description": "Summarizes captured ideas, overnight PRs, blockers, and next recommended actions.",
      "riskLevel": "safe",
      "allowedOperations": ["summarize_projects", "summarize_ideas", "draft_status_note"],
      "blockedOperations": ["send_report", "publish_report", "expose_private_data"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "notes": "Reports are draft notes or dashboard summaries until communications are explicitly reviewed."
    },
    {
      "id": "local-agent",
      "displayName": "Local Agent Bridge",
      "category": "local-control",
      "status": "scaffold-only",
      "mode": "localhost-allowlist",
      "description": "Optional localhost bridge for approved local actions after explicit confirmation.",
      "riskLevel": "high",
      "allowedOperations": ["run_approved_test", "open_url", "write_local_vault"],
      "blockedOperations": ["arbitrary_shell", "install_packages", "delete_files", "screen_control", "keyboard_control", "mouse_control"],
      "confirmationRequired": true,
      "requiredEnvVars": ["LOCAL_AGENT_URL", "LOCAL_AGENT_TOKEN"],
      "notes": "No arbitrary shell execution, deletion, or UI control."
    }
  ]
}
