{
  "version": 1,
  "policy": "honest-status-only",
  "description": "CopelandOS command-center integration registry. Entries describe the intended control loop without claiming external services are connected.",
  "controlLoop": [
    "iphone-shortcuts",
    "copelandos-inbox",
    "idea-classifier",
    "planner",
    "provider-router",
    "tool-mcp-registry",
    "obsidian-git-vault",
    "cursor-codex-queue",
    "draft-pr-status",
    "morning-report"
  ],
  "integrations": [
    {
      "id": "iphone-shortcuts",
      "displayName": "iPhone Shortcuts / Siri",
      "layer": "capture",
      "kind": "external-client",
      "status": "scaffold",
      "purpose": "Capture dictated or share-sheet ideas into the CopelandOS inbox.",
      "entrypoints": ["POST /api/capture/idea"],
      "requiredEnvVars": ["ALLOWED_ORIGIN"],
      "safeActions": ["capture_text", "attach_source", "attach_tags"],
      "blockedActions": ["execute_code", "send_email", "merge_pr"],
      "docs": ["docs/mobile-command-center.md", "docs/mobile-capture.md"]
    },
    {
      "id": "ios-widget",
      "displayName": "iOS Widget / App Intent Surface",
      "layer": "capture",
      "kind": "future-client",
      "status": "scaffold",
      "purpose": "Expose quick capture, inbox count, and morning report summaries from a future native iOS client.",
      "entrypoints": ["GET /api/status", "GET /api/ideas", "POST /api/capture/idea"],
      "requiredEnvVars": ["ALLOWED_ORIGIN"],
      "safeActions": ["show_status", "capture_text", "open_dashboard"],
      "blockedActions": ["execute_code", "install_shortcut", "control_device"],
      "docs": ["docs/mobile-command-center.md"]
    },
    {
      "id": "copelandos-inbox",
      "displayName": "CopelandOS Inbox",
      "layer": "capture",
      "kind": "internal-module",
      "status": "internal",
      "purpose": "Store captured ideas until human triage or conversion.",
      "entrypoints": ["POST /api/capture/idea", "GET /api/ideas"],
      "requiredEnvVars": [],
      "safeActions": ["create_idea", "list_ideas", "triage_idea"],
      "blockedActions": ["execute_idea", "delete_private_data"],
      "docs": ["docs/mobile-command-center.md"]
    },
    {
      "id": "idea-classifier",
      "displayName": "Idea Classifier",
      "layer": "brain",
      "kind": "internal-module",
      "status": "internal",
      "purpose": "Assign category, risk, skill, and suggested action using deterministic rules.",
      "entrypoints": ["src/ideaClassifier.js"],
      "requiredEnvVars": [],
      "safeActions": ["classify_text", "flag_risk", "suggest_skill"],
      "blockedActions": ["execute_action", "override_permission"],
      "docs": ["docs/ai-brain.md", "docs/mobile-command-center.md"]
    },
    {
      "id": "planner",
      "displayName": "Planner",
      "layer": "brain",
      "kind": "internal-module",
      "status": "internal",
      "purpose": "Turn approved ideas into scoped plans and agent prompts.",
      "entrypoints": ["POST /api/plan", "POST /api/plan/brief"],
      "requiredEnvVars": [],
      "safeActions": ["create_plan", "create_task_brief", "select_roles"],
      "blockedActions": ["deploy", "merge_pr", "send_email"],
      "docs": ["docs/overnight-control-loop.md", "docs/cursor-codex-workflow.md"]
    },
    {
      "id": "provider-router",
      "displayName": "Provider Router",
      "layer": "routing",
      "kind": "internal-module",
      "status": "internal",
      "purpose": "Choose the first configured provider in a task-specific route and expose local fallback status.",
      "entrypoints": ["POST /api/ai/route", "GET /api/providers", "POST /api/providers/route"],
      "requiredEnvVars": [],
      "safeActions": ["route_model", "explain_route", "show_fallbacks"],
      "blockedActions": ["spend_without_budget", "fake_provider_connection"],
      "docs": ["docs/provider-routing-roadmap.md", "docs/provider-strategy.md"]
    },
    {
      "id": "ai-council",
      "displayName": "AI Council",
      "layer": "routing",
      "kind": "internal-scaffold",
      "status": "scaffold",
      "purpose": "Run multi-role review for complex tasks; current Worker route returns mock council output.",
      "entrypoints": ["POST /api/council"],
      "requiredEnvVars": [],
      "safeActions": ["create_mock_council_result", "produce_final_plan"],
      "blockedActions": ["claim_live_council", "auto_execute_plan"],
      "docs": ["docs/ai-council.md", "docs/provider-routing-roadmap.md"]
    },
    {
      "id": "tool-mcp-registry",
      "displayName": "Tool / MCP Allowlist Registry",
      "layer": "safety",
      "kind": "internal-module",
      "status": "internal",
      "purpose": "Gate tools and MCP servers through explicit allowlists and blocked action lists.",
      "entrypoints": ["GET /api/tools", "POST /api/tools/check", "GET /api/mcp/registry", "POST /api/mcp/check"],
      "requiredEnvVars": [],
      "safeActions": ["list_tools", "check_tool", "check_mcp"],
      "blockedActions": ["arbitrary_shell", "delete_files", "send_message", "deploy"],
      "docs": ["docs/tool-permissions.md", "docs/mcp-policy.md", "docs/dream-integrations.md"]
    },
    {
      "id": "obsidian-git-vault",
      "displayName": "Obsidian Git Vault",
      "layer": "memory",
      "kind": "external-service",
      "status": "external",
      "purpose": "Persist reviewed notes into a private Git-backed Obsidian vault.",
      "entrypoints": ["POST /api/vault/write", "POST /api/obsidian/open"],
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"],
      "safeActions": ["write_note", "open_uri", "preview_mock_write"],
      "blockedActions": ["store_private_student_data", "make_public", "delete_vault"],
      "docs": ["docs/obsidian-cursor-workflow.md", "docs/obsidian-vault.md"]
    },
    {
      "id": "cursor-codex-queue",
      "displayName": "Cursor / Codex Task Queue",
      "layer": "execution",
      "kind": "internal-scaffold",
      "status": "scaffold",
      "purpose": "Generate branch-safe implementation prompts; future queue execution must remain PR-first.",
      "entrypoints": ["POST /api/agents/cursor-prompt", "POST /api/agents/codex-prompt", "POST /api/ideas/:id/cursor-prompt"],
      "requiredEnvVars": [],
      "safeActions": ["generate_prompt", "create_task_brief"],
      "blockedActions": ["auto_merge", "auto_deploy", "run_arbitrary_shell"],
      "docs": ["docs/cursor-codex-workflow.md", "docs/overnight-control-loop.md"]
    },
    {
      "id": "draft-pr-status",
      "displayName": "Draft PR Status",
      "layer": "review",
      "kind": "external-service",
      "status": "external",
      "purpose": "Summarize open draft PRs and check results once a scoped GitHub read connector is implemented.",
      "entrypoints": ["GET /api/github/summary"],
      "requiredEnvVars": ["GITHUB_TOKEN"],
      "safeActions": ["read_prs", "read_checks", "summarize_status"],
      "blockedActions": ["merge_pr", "close_pr", "push_to_main"],
      "docs": ["docs/overnight-control-loop.md"]
    },
    {
      "id": "morning-report",
      "displayName": "Morning Report",
      "layer": "review",
      "kind": "internal-scaffold",
      "status": "scaffold",
      "purpose": "Produce a review-first daily summary from inbox, vault, provider, and PR status signals.",
      "entrypoints": ["GET /api/status", "GET /api/projects", "GET /api/ideas"],
      "requiredEnvVars": [],
      "safeActions": ["summarize_status", "list_next_steps", "flag_blockers"],
      "blockedActions": ["send_email", "deploy", "claim_completion"],
      "docs": ["docs/overnight-control-loop.md", "docs/mobile-command-center.md"]
    }
  ]
}
