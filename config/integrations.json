{
  "version": 1,
  "description": "CopelandOS command-center integration registry. Entries are roadmap/scaffold unless connection evidence is present; never use this file to imply a connector is live.",
  "controlLoop": [
    "phone-or-siri",
    "copelandos-inbox",
    "classifier",
    "planner",
    "provider-router-or-ai-council",
    "safe-tool-registry",
    "obsidian-memory",
    "cursor-codex-task",
    "draft-pr",
    "review-status"
  ],
  "integrations": [
    {
      "id": "iphone-shortcuts",
      "displayName": "iPhone Shortcuts and Share Sheet",
      "surface": "mobile",
      "stage": "scaffold",
      "connectionMode": "manual-client",
      "entrypoints": ["Siri phrase", "Shortcuts widget", "Share Sheet"],
      "requiredEnvVars": [],
      "allowedInboundRoutes": ["/api/capture/idea"],
      "allowedActions": ["capture_text", "capture_url", "capture_image_reference"],
      "blockedActions": ["execute_task", "send_email", "merge_pr", "deploy"],
      "dataClasses": ["idea_text", "shared_url", "optional_image_reference"],
      "safetyNotes": "Shortcuts may submit ideas to the inbox only. Captured content is classified and planned later; it is never executed directly."
    },
    {
      "id": "copelandos-inbox",
      "displayName": "CopelandOS Inbox",
      "surface": "worker",
      "stage": "active",
      "connectionMode": "internal-module",
      "entrypoints": ["/api/capture/idea", "/api/ideas"],
      "requiredEnvVars": [],
      "allowedInboundRoutes": ["/api/capture/idea", "/api/ideas"],
      "allowedActions": ["store_idea", "list_ideas", "triage_idea"],
      "blockedActions": ["execute_task", "publish_private_data"],
      "dataClasses": ["idea_text", "classification_metadata"],
      "safetyNotes": "The inbox records ideas and statuses in process memory for the foundation scaffold; private student data must not be stored."
    },
    {
      "id": "classifier-planner",
      "displayName": "Classifier and Planner",
      "surface": "worker",
      "stage": "active",
      "connectionMode": "internal-module",
      "entrypoints": ["/api/plan", "/api/plan/brief", "/api/ideas/:id/triage"],
      "requiredEnvVars": [],
      "allowedInboundRoutes": ["/api/plan", "/api/plan/brief"],
      "allowedActions": ["classify_idea", "create_plan", "create_task_brief"],
      "blockedActions": ["execute_plan", "override_permissions"],
      "dataClasses": ["idea_text", "task_metadata"],
      "safetyNotes": "Classification is advisory. The planner returns steps, warnings, and prompt text; it does not run tools."
    },
    {
      "id": "provider-router",
      "displayName": "Provider Router and AI Council",
      "surface": "ai",
      "stage": "active",
      "connectionMode": "env-gated",
      "entrypoints": ["/api/providers", "/api/providers/route", "/api/council"],
      "requiredEnvVarsAny": ["GROQ_API_KEY", "CEREBRAS_API_KEY", "GEMINI_API_KEY", "OPENROUTER_API_KEY", "ANTHROPIC_API_KEY", "OPENAI_API_KEY", "OLLAMA_BASE_URL"],
      "allowedInboundRoutes": ["/api/providers", "/api/providers/route", "/api/council"],
      "allowedActions": ["route_task", "explain_route", "create_mock_council_plan"],
      "blockedActions": ["claim_unconfigured_provider_connected", "spend_without_policy"],
      "dataClasses": ["task_metadata", "prompt_text"],
      "safetyNotes": "Provider status is true only when a configured environment variable exists. Council mode is a plan/prompt scaffold unless provider calls are explicitly routed."
    },
    {
      "id": "safe-tool-registry",
      "displayName": "Tool and MCP Allowlist Registry",
      "surface": "tools",
      "stage": "active",
      "connectionMode": "internal-module",
      "entrypoints": ["/api/tools", "/api/tools/check", "/api/mcp/registry", "/api/mcp/check"],
      "requiredEnvVars": [],
      "allowedInboundRoutes": ["/api/tools", "/api/tools/check", "/api/mcp/registry", "/api/mcp/check"],
      "allowedActions": ["list_tools", "check_tool_permission", "list_mcp_servers", "check_mcp_permission"],
      "blockedActions": ["arbitrary_shell", "delete_file", "send_email", "merge_pr", "deploy"],
      "dataClasses": ["tool_metadata", "policy_metadata"],
      "safetyNotes": "Unknown tools and unknown MCP servers are blocked. Sensitive operations require human confirmation or are permanently blocked."
    },
    {
      "id": "obsidian-git-vault",
      "displayName": "Obsidian Git Vault",
      "surface": "memory",
      "stage": "scaffold",
      "connectionMode": "env-gated",
      "entrypoints": ["/api/vault/write", "/api/obsidian/open"],
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"],
      "optionalEnvVars": ["VAULT_ROOT", "VAULT_BRANCH", "OBSIDIAN_VAULT"],
      "allowedInboundRoutes": ["/api/vault/write", "/api/obsidian/open"],
      "allowedActions": ["write_bounded_note", "return_obsidian_uri", "preview_mock_note"],
      "blockedActions": ["delete_vault", "make_public", "store_private_student_data"],
      "dataClasses": ["sanitized_markdown_note", "vault_path"],
      "safetyNotes": "Writes require a private vault repository and path validation. Without env vars, the API returns a mock preview rather than claiming persistence."
    },
    {
      "id": "cursor-codex-task-queue",
      "displayName": "Cursor and Codex Task Queue",
      "surface": "github",
      "stage": "scaffold",
      "connectionMode": "draft-only",
      "entrypoints": ["/api/agents/cursor-prompt", "/api/agents/codex-prompt", "/api/ideas/:id/cursor-prompt", "/api/ideas/:id/codex-prompt"],
      "requiredEnvVars": [],
      "allowedInboundRoutes": ["/api/agents/cursor-prompt", "/api/agents/codex-prompt"],
      "allowedActions": ["generate_cursor_prompt", "generate_codex_prompt", "mark_ready_for_agent"],
      "blockedActions": ["run_agent_without_review", "push_to_main", "merge_pr", "deploy"],
      "dataClasses": ["task_prompt", "project_policy"],
      "safetyNotes": "The queue generates bounded prompts and statuses only. Agents must run on branches and open draft PRs; no merge or deploy is automated."
    },
    {
      "id": "morning-report",
      "displayName": "Morning Report and Project Status",
      "surface": "dashboard",
      "stage": "roadmap",
      "connectionMode": "not-implemented",
      "entrypoints": ["dashboard card", "future /api/morning-report"],
      "requiredEnvVars": [],
      "allowedInboundRoutes": [],
      "allowedActions": ["summarize_status", "show_review_queue", "show_blockers"],
      "blockedActions": ["auto_message_people", "auto_merge", "auto_close_issue"],
      "dataClasses": ["public_project_status", "local_task_status"],
      "safetyNotes": "Future report must summarize draft PRs, checks, and blockers without posting messages or exposing private data."
    }
  ]
}
