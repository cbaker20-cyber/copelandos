{
  "version": 1,
  "tools": [
    {
      "id": "github-read-repo",
      "family": "github",
      "displayName": "Read GitHub repo",
      "description": "Read repository contents, files, PRs, issues, and CI status.",
      "riskLevel": "safe",
      "category": "read-only",
      "allowedActions": ["list_files", "read_file", "list_prs", "list_issues", "get_pr", "get_issue", "get_run_status"],
      "blockedActions": ["create_pr", "merge_pr", "delete_branch", "push_commit"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN"]
    },
    {
      "id": "github-create-issue",
      "family": "github",
      "displayName": "Create GitHub issue",
      "description": "Create a new issue on a repository.",
      "riskLevel": "medium",
      "category": "safe-write",
      "allowedActions": ["create_issue"],
      "blockedActions": ["delete_issue", "create_pr", "merge_pr"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN"]
    },
    {
      "id": "github-merge-pr",
      "family": "github",
      "displayName": "Merge GitHub PR",
      "description": "Merge a pull request. High risk — always requires human confirmation.",
      "riskLevel": "high",
      "category": "confirmation-required",
      "allowedActions": [],
      "blockedActions": ["merge_pr"],
      "confirmationRequired": true,
      "requiredEnvVars": ["GITHUB_TOKEN"],
      "notes": "Merge operations require explicit human confirmation. Never automatic."
    },
    {
      "id": "gmail-draft",
      "family": "gmail",
      "displayName": "Gmail draft creator",
      "description": "Create draft emails only. Never sends.",
      "riskLevel": "medium",
      "category": "draft-only",
      "allowedActions": ["create_draft", "read_draft", "list_drafts"],
      "blockedActions": ["send_email", "delete_email", "modify_label"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GMAIL_REFRESH_TOKEN", "GMAIL_CLIENT_ID", "GMAIL_CLIENT_SECRET"],
      "notes": "Gmail is permanently draft-only in CopelandOS. Sending requires explicit PR change."
    },
    {
      "id": "gmail-send",
      "family": "gmail",
      "displayName": "Gmail send (BLOCKED)",
      "description": "Sending email is blocked in CopelandOS.",
      "riskLevel": "high",
      "category": "blocked",
      "allowedActions": [],
      "blockedActions": ["send_email"],
      "confirmationRequired": true,
      "requiredEnvVars": [],
      "notes": "Email sending is permanently blocked. Draft-only mode is enforced."
    },
    {
      "id": "obsidian-vault-write",
      "family": "obsidian",
      "displayName": "Obsidian vault writer",
      "description": "Write notes, ideas, and documents to the CopelandVault.",
      "riskLevel": "safe",
      "category": "safe-write",
      "allowedActions": ["write_note", "append_daily", "write_idea", "write_research", "write_decision", "write_meeting", "write_tasks"],
      "blockedActions": ["delete_note", "move_vault", "delete_folder"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"],
      "notes": "Vault writes are sanitized. Path traversal and secrets are blocked."
    },
    {
      "id": "obsidian-vault-read",
      "family": "obsidian",
      "displayName": "Obsidian vault reader",
      "description": "List and read notes from the CopelandVault.",
      "riskLevel": "safe",
      "category": "read-only",
      "allowedActions": ["list_files", "read_note"],
      "blockedActions": [],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"]
    },
    {
      "id": "local-agent-status",
      "family": "local-agent",
      "displayName": "Local agent status",
      "description": "Read status from the local Windows agent.",
      "riskLevel": "safe",
      "category": "read-only",
      "allowedActions": ["read_status"],
      "blockedActions": [],
      "confirmationRequired": false,
