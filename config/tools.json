      "riskLevel": "medium",
      "category": "confirmation-required",
      "allowedActions": ["open_project_folder", "start_cursor", "run_approved_test"],
      "blockedActions": ["arbitrary_shell", "delete_file", "control_screen", "control_mouse", "control_keyboard", "take_screenshot", "install_package"],
      "confirmationRequired": true,
      "requiredEnvVars": ["LOCAL_AGENT_URL", "LOCAL_AGENT_TOKEN"]
    },
    {
      "id": "web-search",
