{
  "version": 1,
  "categories": {
    "read-only": "Retrieve information without side effects",
    "draft-only": "Create drafts for human review; never publish automatically",
    "safe-write": "Write to controlled, private storage after validation",
    "confirmation-required": "Requires explicit human confirmation before any action",
    "blocked": "Never permitted; not configurable"
  },
  "tools": [
    {
      "id": "github-read",
      "displayName": "GitHub Read",
      "family": "github",
      "category": "read-only",
      "description": "Read repository contents, PRs, issues, and checks",
      "riskLevel": "safe",
      "allowedActions": ["list_repos", "read_file", "list_prs", "read_issue", "get_check_status"],
      "blockedActions": ["merge_pr", "delete_branch", "push_commit", "close_pr"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN"]
    },
    {
      "id": "github-issue",
      "displayName": "GitHub Issue Create",
      "family": "github",
      "category": "confirmation-required",
      "description": "Create GitHub issues for planning purposes",
      "riskLevel": "medium",
      "allowedActions": ["create_issue", "add_label"],
      "blockedActions": ["merge_pr", "close_repo", "delete_branch", "push_to_main"],
      "confirmationRequired": true,
      "requiredEnvVars": ["GITHUB_TOKEN"]
    },
    {
      "id": "gmail-draft",
      "displayName": "Gmail Draft",
      "family": "gmail",
      "category": "draft-only",
      "description": "Create Gmail drafts for human review and sending",
      "riskLevel": "medium",
      "allowedActions": ["create_draft", "list_messages", "read_message"],
      "blockedActions": ["send_message", "delete_message", "modify_labels"],
      "confirmationRequired": true,
      "requiredEnvVars": ["GMAIL_CLIENT_ID", "GMAIL_CLIENT_SECRET", "GMAIL_REFRESH_TOKEN"],
      "note": "Gmail is draft-only. This policy cannot be changed without a reviewed PR."
    },
    {
      "id": "gmail-send",
      "displayName": "Gmail Send",
      "family": "gmail",
      "category": "blocked",
      "description": "Sending email is permanently blocked in this system",
      "riskLevel": "high",
      "allowedActions": [],
      "blockedActions": ["send_message"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "note": "Email sending is blocked. Use gmail-draft instead."
    },
    {
      "id": "google-calendar",
      "displayName": "Google Calendar",
      "family": "google-calendar",
      "category": "confirmation-required",
      "description": "Read calendar events and create draft events",
      "riskLevel": "medium",
      "allowedActions": ["list_events", "read_event", "create_draft_event"],
      "blockedActions": ["delete_event", "share_calendar", "make_public"],
      "confirmationRequired": true,
      "requiredEnvVars": ["GOOGLE_CALENDAR_TOKEN"],
      "note": "Not yet implemented. Scaffold only."
    },
    {
      "id": "obsidian-vault",
      "displayName": "Obsidian Vault",
      "family": "obsidian",
      "category": "safe-write",
      "description": "Write notes to the private Obsidian GitHub vault",
      "riskLevel": "safe",
      "allowedActions": ["write_note", "read_note", "list_notes", "create_folder"],
      "blockedActions": ["delete_vault", "make_public", "expose_private_student_data"],
      "confirmationRequired": false,
      "requiredEnvVars": ["GITHUB_TOKEN", "GITHUB_REPO"]
    },
    {
      "id": "local-agent",
      "displayName": "Local Agent",
      "family": "local-agent",
      "category": "confirmation-required",
      "description": "Permissioned local PC actions via localhost agent",
      "riskLevel": "medium",
      "allowedActions": ["launch_app", "run_approved_test", "open_url", "write_local_vault"],
      "blockedActions": ["arbitrary_shell", "delete_files", "install_packages", "screen_control", "keyboard_control", "mouse_control"],
      "confirmationRequired": true,
      "requiredEnvVars": ["LOCAL_AGENT_URL", "LOCAL_AGENT_TOKEN"]
    },
    {
      "id": "web-search",
      "displayName": "Web Search",
      "family": "web",
      "category": "read-only",
      "description": "Search the web via Serper API",
      "riskLevel": "safe",
      "allowedActions": ["search", "fetch_url"],
      "blockedActions": ["post_content", "submit_form"],
      "confirmationRequired": false,
      "requiredEnvVars": ["SERPER_KEY"]
    },
    {
      "id": "files-read",
      "displayName": "File Read",
      "family": "files",
      "category": "read-only",
      "description": "Read local files via the local agent allowlist",
      "riskLevel": "safe",
      "allowedActions": ["read_file", "list_directory"],
      "blockedActions": ["write_file", "delete_file", "execute_file"],
      "confirmationRequired": false,
      "requiredEnvVars": ["LOCAL_AGENT_URL", "LOCAL_AGENT_TOKEN"]
    },
    {
      "id": "files-write",
      "displayName": "File Write",
      "family": "files",
      "category": "confirmation-required",
      "description": "Write to allowed local paths via the local agent",
      "riskLevel": "medium",
      "allowedActions": ["write_to_vault_path"],
      "blockedActions": ["delete_file", "overwrite_system_files", "arbitrary_path"],
      "confirmationRequired": true,
      "requiredEnvVars": ["LOCAL_AGENT_URL", "LOCAL_AGENT_TOKEN"]
    },
    {
      "id": "files-delete",
      "displayName": "File Delete",
      "family": "files",
      "category": "blocked",
      "description": "File deletion is permanently blocked",
      "riskLevel": "high",
      "allowedActions": [],
      "blockedActions": ["delete_file", "rm", "rmdir", "unlink"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "note": "File deletion is never permitted by this system."
    },
    {
      "id": "cursor-task",
      "displayName": "Cursor Task Generation",
      "family": "cursor-codex",
      "category": "safe-write",
      "description": "Generate scoped Cursor implementation prompts",
      "riskLevel": "safe",
      "allowedActions": ["generate_cursor_prompt", "generate_codex_prompt"],
      "blockedActions": ["execute_in_cursor", "auto_merge", "auto_deploy"],
      "confirmationRequired": false,
      "requiredEnvVars": []
    },
    {
      "id": "deploy",
      "displayName": "Deploy",
      "family": "devops",
      "category": "blocked",
      "description": "Deployments are blocked pending explicit human approval",
      "riskLevel": "high",
      "allowedActions": [],
      "blockedActions": ["deploy", "publish", "release", "wrangler_publish"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "note": "Deployments require human review and must not be triggered automatically."
    },
    {
      "id": "screen-control",
      "displayName": "Screen Control",
      "family": "local-agent",
      "category": "blocked",
      "description": "Screen, mouse, and keyboard control are permanently blocked",
      "riskLevel": "high",
      "allowedActions": [],
      "blockedActions": ["take_screenshot", "click", "type_keys", "move_mouse", "control_screen"],
      "confirmationRequired": false,
      "requiredEnvVars": [],
      "note": "No UI automation is ever permitted."
    }
  ]
}
