{
  "version": 1,
  "mode": "github-or-mock",
  "defaultRoot": "CopelandVault",
  "requiredEnvVarsForGitHubMode": ["GITHUB_TOKEN", "GITHUB_REPO"],
  "optionalEnvVars": ["VAULT_ROOT", "VAULT_BRANCH"],
  "folders": [
    "Daily",
    "Projects",
    "School",
    "BandCouncil",
    "Music",
    "Research",
    "Decisions",
    "Inbox",
    "Templates"
  ],
  "ideaInbox": {
    "folder": "Inbox",
    "captureTemplate": "templates/idea-capture.md",
    "triageTemplate": "templates/idea-triage.md",
    "dailyAppendFolder": "Daily",
    "automaticExecution": false
  },
  "conversionTypes": [
    "project-update",
    "decision-log",
    "research-note",
    "meeting-note",
    "task-list",
    "email-draft-note",
    "idea-note"
  ],
  "safety": {
    "sanitizeFilenames": true,
    "blockPathTraversal": true,
    "blockObviousSecrets": true,
    "blockObviousPrivateStudentData": true,
    "emailDraftOnly": true
  }
}
