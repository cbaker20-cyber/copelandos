{
  "goal": "Run CopelandOS with the most free/open-source/local AI coverage possible, using approval gates for risky actions.",
  "local_models": {
    "fast_default": ["qwen2.5-coder:7b", "llama3.2:3b", "gemma3:4b"],
    "coding": ["qwen2.5-coder:14b", "deepseek-coder-v2:16b", "starcoder2:7b"],
    "reasoning": ["qwen3:8b", "llama3.1:8b", "mistral-nemo:12b"],
    "large_when_possible": ["qwen2.5-coder:32b", "llama3.3:70b-instruct-q4", "mixtral:8x7b-instruct"],
    "embeddings": ["nomic-embed-text", "mxbai-embed-large"]
  },
  "runtimes": [
    { "id": "ollama", "role": "easy local model runtime", "port": 11434, "required": true },
    { "id": "open_webui", "role": "local chat dashboard", "port": 3000, "required": false },
    { "id": "litellm", "role": "OpenAI-compatible router/budget layer", "port": 4000, "required": false },
    { "id": "vllm", "role": "high-throughput GPU server for larger models", "required": false },
    { "id": "llama.cpp", "role": "fallback CPU/GPU runtime and GGUF server", "required": false }
  ],
  "agents": [
    { "id": "openhands", "role": "sandboxed coding agent", "risk": "medium" },
    { "id": "aider", "role": "git-aware pair programmer", "risk": "medium" },
    { "id": "browser_use", "role": "sandboxed browser automation", "risk": "high" },
    { "id": "langgraph", "role": "durable workflow graph", "risk": "medium" },
    { "id": "autogen", "role": "multi-agent debate/team workflows", "risk": "medium" },
    { "id": "crewai", "role": "role-based school/productivity crews", "risk": "medium" },
    { "id": "ornith", "role": "experimental harness/eval builder", "risk": "high" }
  ],
  "memory": [
    { "id": "qdrant", "role": "vector memory", "port": 6333 },
    { "id": "chromadb", "role": "local vector memory alternative", "port": 8000 }
  ],
  "safety": {
    "default_execute": false,
    "requires_approval": ["email_send", "calendar_write", "drive_move", "webhook_fire", "desktop_control", "delete", "deploy", "merge"],
    "allowed_without_approval": ["plan", "summarize", "draft", "preview_payload", "run_sandbox_test"]
  }
}
