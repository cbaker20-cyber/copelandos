{
  "version": 1,
  "strategy": "no-single-subscription-dependency",
  "description": "CopelandOS multi-provider routing: free tiers, student credits, local fallback, and failover chains. Never lock in to one paid provider.",
  "providers": [
    {
      "id": "openrouter-free",
      "displayName": "OpenRouter (free tier)",
      "type": "openrouter",
      "modelAlias": "qwen/qwen3-coder:free",
      "envKey": "OPENROUTER_API_KEY",
      "legacyEnvKey": "OPENROUTER_KEY",
      "taskStrengths": ["coding", "reasoning", "planning"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "medium",
      "costTier": "free",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 2,
      "notes": "Free tier available. Good for coding and reasoning without subscription."
    },
    {
      "id": "openrouter-fusion",
      "displayName": "OpenRouter Fusion (council routing)",
      "type": "openrouter-fusion",
      "modelAlias": "openrouter/auto",
      "envKey": "OPENROUTER_API_KEY",
      "legacyEnvKey": "OPENROUTER_KEY",
      "taskStrengths": ["council", "complex-reasoning", "multi-model"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "slow",
      "costTier": "pay-per-token",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 5,
      "notes": "Routes across multiple models. Best for council mode when budget allows."
    },
    {
      "id": "groq",
      "displayName": "Groq",
      "type": "groq",
      "modelAlias": "llama-4-scout-17b-16e-instruct",
      "envKey": "GROQ_API_KEY",
      "legacyEnvKey": "GROQ_KEY",
      "taskStrengths": ["fast", "summarization", "coding"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "medium",
      "speedTier": "fast",
      "costTier": "free-tier",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 1,
      "notes": "Free tier with high rate limits. Excellent for fast tasks."
    },
    {
      "id": "cerebras",
      "displayName": "Cerebras",
      "type": "cerebras",
      "modelAlias": "llama-4-scout-17b-16e-instruct",
      "envKey": "CEREBRAS_API_KEY",
      "legacyEnvKey": "CEREBRAS_KEY",
      "taskStrengths": ["fast", "coding", "summarization"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": true,
      "contextTier": "medium",
      "speedTier": "ultra-fast",
      "costTier": "free-tier",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 1,
      "notes": "Extremely fast inference. Great for real-time idea capture classification."
    },
    {
      "id": "gemini-flash",
      "displayName": "Gemini Flash",
      "type": "gemini",
      "modelAlias": "gemini-2.5-flash",
      "envKey": "GEMINI_API_KEY",
      "legacyEnvKey": "GEMINI_KEY",
      "taskStrengths": ["research", "reasoning", "music", "multimodal"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "fast",
      "costTier": "free-tier",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 2,
      "notes": "Free tier available. Good for research and multimodal tasks."
    },
    {
      "id": "anthropic",
      "displayName": "Anthropic (Claude)",
      "type": "anthropic",
      "modelAlias": "claude-sonnet-4-20250514",
      "envKey": "ANTHROPIC_API_KEY",
      "taskStrengths": ["reasoning", "security-review", "planning", "coding"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "medium",
      "costTier": "pay-per-token",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 4,
      "notes": "Best for complex reasoning and security review. Paid only."
    },
    {
      "id": "openai",
      "displayName": "OpenAI",
      "type": "openai",
      "modelAlias": "gpt-4.1-mini",
      "envKey": "OPENAI_API_KEY",
      "taskStrengths": ["reasoning", "coding", "planning"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "medium",
      "costTier": "pay-per-token",
      "privacyTier": "cloud",
      "offline": false,
      "fallbackOrder": 3,
      "notes": "Reliable baseline. Paid only."
    },
    {
      "id": "ollama",
      "displayName": "Ollama (local)",
      "type": "ollama",
      "modelAlias": "llama3.2",
      "envKey": "OLLAMA_BASE_URL",
      "taskStrengths": ["all tasks offline", "privacy", "local-fallback"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": false,
      "contextTier": "small",
      "speedTier": "slow",
      "costTier": "free",
      "privacyTier": "local",
      "offline": true,
      "fallbackOrder": 10,
      "notes": "Local model via Ollama. No internet required. Privacy-first. Slower quality but always available if running."
    },
    {
      "id": "litellm",
      "displayName": "LiteLLM Gateway",
      "type": "litellm",
      "modelAlias": "configured-by-gateway",
      "envKey": "LITELLM_BASE_URL",
      "taskStrengths": ["all tasks via proxy", "unified API"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "depends-on-model",
      "speedTier": "depends-on-model",
      "costTier": "depends-on-model",
      "privacyTier": "depends-on-deployment",
      "offline": false,
      "fallbackOrder": 6,
      "notes": "LiteLLM gateway as a unified proxy. Not implemented in this PR; scaffold only."
    }
  ],
  "routingStrategy": {
    "fast": ["groq", "cerebras", "gemini-flash", "openai", "ollama"],
    "reasoning": ["anthropic", "openai", "gemini-flash", "openrouter-free", "ollama"],
    "coding": ["anthropic", "openai", "openrouter-free", "gemini-flash", "ollama"],
    "summarization": ["groq", "cerebras", "gemini-flash", "openai", "ollama"],
    "research": ["openai", "anthropic", "gemini-flash", "openrouter-free", "ollama"],
    "planning": ["anthropic", "openai", "gemini-flash", "openrouter-free", "ollama"],
    "music": ["openai", "anthropic", "gemini-flash", "openrouter-free", "ollama"],
    "security_review": ["anthropic", "openai", "gemini-flash", "openrouter-free", "ollama"],
    "council": ["openrouter-fusion", "anthropic", "openai", "gemini-flash", "ollama"],
    "local_fallback": ["ollama"]
  },
  "failoverPolicy": {
    "maxRetries": 2,
    "retryOn": ["rate-limited", "timeout", "server-error"],
    "budgetGuard": "Never spend more than one token tier above the cheapest configured option unless council mode is active.",
    "localFallback": "Always represent Ollama as available even if not running. Client should detect and display accordingly."
  },
  "noSubscriptionRoutes": {
    "description": "Routes available without any paid subscription",
    "providers": ["groq", "cerebras", "gemini-flash", "openrouter-free", "ollama"],
    "note": "All free-tier providers require an API key registration but no credit card or paid plan."
  }
}
