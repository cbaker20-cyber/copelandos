{
  "version": 1,
  "providers": [
    {
      "id": "openai",
      "modelAlias": "gpt-4o",
      "displayName": "OpenAI GPT-4o",
      "envVar": "OPENAI_API_KEY",
      "taskStrengths": ["coding", "reasoning", "writing", "analysis"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "medium",
      "costTier": "paid",
      "privacyTier": "cloud",
      "offlineLocal": false,
      "fallbackOrder": 2,
      "freeOption": false,
      "notes": "Best general-purpose provider. Requires paid key."
    },
    {
      "id": "anthropic",
      "modelAlias": "claude-3-5-sonnet-20241022",
      "displayName": "Anthropic Claude 3.5 Sonnet",
      "envVar": "ANTHROPIC_API_KEY",
      "taskStrengths": ["reasoning", "coding", "analysis", "writing", "security-review"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "large",
      "speedTier": "medium",
      "costTier": "paid",
      "privacyTier": "cloud",
      "offlineLocal": false,
      "fallbackOrder": 3,
      "freeOption": false,
      "notes": "Strong at reasoning and security review. Requires paid key."
    },
    {
      "id": "openrouter",
      "modelAlias": "qwen/qwen3-coder:free",
      "displayName": "OpenRouter (free tier)",
      "envVar": "OPENROUTER_API_KEY",
      "taskStrengths": ["coding", "general", "council-routing"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": false,
      "contextTier": "medium",
      "speedTier": "variable",
      "costTier": "free",
      "privacyTier": "cloud",
      "offlineLocal": false,
      "fallbackOrder": 1,
      "freeOption": true,
      "councilRouting": true,
      "notes": "Free tier available. Good for multi-model council routing via OpenRouter Fusion."
    },
    {
      "id": "cerebras",
      "modelAlias": "llama-4-scout-17b-16e-instruct",
      "displayName": "Cerebras (fast inference)",
      "envVar": "CEREBRAS_API_KEY",
      "altEnvVar": "CEREBRAS_KEY",
      "taskStrengths": ["coding", "fast-response", "draft"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": false,
      "contextTier": "medium",
      "speedTier": "fast",
      "costTier": "free-tier",
      "privacyTier": "cloud",
      "offlineLocal": false,
      "fallbackOrder": 1,
      "freeOption": true,
      "notes": "Very fast inference. Good for quick drafts and code. Free tier available."
    },
    {
      "id": "groq",
      "modelAlias": "llama-4-scout-17b-16e-instruct",
      "displayName": "Groq (fast inference)",
      "envVar": "GROQ_API_KEY",
      "altEnvVar": "GROQ_KEY",
      "taskStrengths": ["coding", "fast-response", "draft"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": false,
      "contextTier": "medium",
      "speedTier": "fast",
      "costTier": "free-tier",
      "privacyTier": "cloud",
      "offlineLocal": false,
      "fallbackOrder": 1,
      "freeOption": true,
      "notes": "Very fast inference. Free tier available. Good fallback."
    },
    {
      "id": "gemini",
      "modelAlias": "gemini-2.5-flash",
      "displayName": "Google Gemini 2.5 Flash",
      "envVar": "GEMINI_API_KEY",
      "altEnvVar": "GEMINI_KEY",
      "taskStrengths": ["research", "writing", "analysis", "multimodal"],
      "supportsToolCalling": true,
      "supportsStructuredOutput": true,
      "contextTier": "very-large",
      "speedTier": "medium",
      "costTier": "free-tier",
      "privacyTier": "cloud",
      "offlineLocal": false,
      "fallbackOrder": 2,
      "freeOption": true,
      "notes": "Long context window. Free tier available. Good for research and analysis."
    },
    {
      "id": "ollama",
      "modelAlias": "llama3.2",
      "displayName": "Ollama (local)",
      "envVar": "OLLAMA_BASE_URL",
      "taskStrengths": ["privacy", "offline", "coding", "general"],
      "supportsToolCalling": false,
      "supportsStructuredOutput": false,
      "contextTier": "medium",
      "speedTier": "variable",
      "costTier": "free",
      "privacyTier": "local",
      "offlineLocal": true,
      "fallbackOrder": 0,
      "freeOption": true,
      "notes": "Completely local. Privacy-preserving. Requires local Ollama installation."
    }
  ],
  "routingStrategy": {
    "defaultPreference": ["groq", "cerebras", "openrouter", "gemini", "openai", "anthropic", "ollama"],
    "councilPreference": ["openrouter", "groq", "cerebras", "gemini"],
    "privacyPreference": ["ollama"],
    "codingPreference": ["openai", "anthropic", "openrouter", "groq", "cerebras"],
    "researchPreference": ["gemini", "anthropic", "openai", "openrouter"]
  }
}
