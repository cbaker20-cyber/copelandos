# Exact public origin allowed to call the API from a browser; no trailing slash.
# For the canonical single-Worker deployment, use your Worker URL.
ALLOWED_ORIGIN=https://copelandos.YOUR-SUBDOMAIN.workers.dev

# Provider secrets. Configure only the providers you use.
OPENAI_API_KEY=replace-with-secret
OPENAI_MODEL=replace-with-model-id
ANTHROPIC_API_KEY=replace-with-secret
ANTHROPIC_MODEL=replace-with-model-id
CEREBRAS_API_KEY=replace-with-secret
CEREBRAS_MODEL=replace-with-model-id
GROQ_API_KEY=replace-with-secret
GROQ_MODEL=replace-with-model-id
GEMINI_API_KEY=replace-with-secret
GEMINI_MODEL=replace-with-model-id
OPENROUTER_API_KEY=replace-with-secret
OPENROUTER_MODEL=replace-with-model-id
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=replace-with-local-model-id
SERPER_KEY=replace-with-secret

# Gmail OAuth values. The app saves drafts; it does not send mail.
GMAIL_CLIENT_ID=replace-with-client-id
GMAIL_CLIENT_SECRET=replace-with-client-secret
GMAIL_REFRESH_TOKEN=replace-with-refresh-token

# Optional GitHub-backed vault.
GITHUB_TOKEN=replace-with-fine-grained-token
GITHUB_REPO=your-account/your-private-vault
VAULT_ROOT=Vault
VAULT_BRANCH=main
OBSIDIAN_VAULT=CopelandVault

# Optional local Windows agent. Keep the token outside Git.
LOCAL_AGENT_URL=http://127.0.0.1:43120
LOCAL_AGENT_TOKEN=replace-with-at-least-24-random-characters
LOCAL_AGENT_ALLOWED_ORIGIN=http://127.0.0.1:8787
